        let currentGroup = null;
        
        console.log('EzeeClap loaded');
        
        function toggleCart() {
            document.getElementById('cartPanel').classList.toggle('show');
        }
        
        function addToCart(service) {
            if (cart.find(s => s.display_name === service.display_name)) {
                alert('Already in cart!');
                return;
            }
            cart.push(service);
            updateCartBadge();
            updateCartPanel();
            event.target.textContent = '✓ Added';
            setTimeout(() => { event.target.textContent = 'Add to Cart'; }, 1000);
        }
        
        function removeFromCart(index) {
            cart.splice(index, 1);
            updateCartBadge();
            updateCartPanel();
        }
        
        function updateCartBadge() {
            const badge = document.getElementById('cartBadge');
            if (cart.length > 0) {
                badge.textContent = cart.length;
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }
        }
        
        function updateCartPanel() {
            const itemsDiv = document.getElementById('cartItems');
            if (cart.length === 0) {
                itemsDiv.innerHTML = '<p style="text-align: center; color: #999;">Empty</p>';
                document.getElementById('cartTotal').textContent = 'Total: ₹0';
                return;
            }
            let html = '';
            let total = 0;
            cart.forEach((s, i) => {
                total += s.Price + 99;
                html += '<div class="cart-item"><button class="remove-item" onclick="removeFromCart(' + i + ')">×</button><div class="cart-item-name">' + s.display_name + '</div><div style="color: #FF6B35; font-weight: 700;">₹' + (s.Price + 99) + '</div></div>';
            });
            itemsDiv.innerHTML = html;
            document.getElementById('cartTotal').textContent = 'Total: ₹' + total;
        }
        
        function bookViaWhatsApp() {
            if (cart.length === 0) { alert('Cart is empty!'); return; }
            let msg = 'Hi EzeeClap! I want to book:\n\n';
            let total = 0;
            cart.forEach((s, i) => {
                total += s.Price + 99;
                msg += (i+1) + '. ' + s.display_name + ' - ₹' + (s.Price + 99) + '\n';
            });
            msg += '\nTotal: ₹' + total;
            window.open('https://wa.me/919090910590?text=' + encodeURIComponent(msg), '_blank');
        }
        
        function openBookingForm() {
            if (cart.length === 0) { alert('Cart is empty!'); return; }
            let summary = '<h3 style="margin-bottom: 12px;">Services:</h3>';
            let total = 0;
            cart.forEach((s, i) => {
                total += s.Price + 99;
                summary += '<div style="margin: 8px 0;"><strong>' + (i+1) + '.</strong> ' + s.display_name + ' - ₹' + (s.Price + 99) + '</div>';
            });
            summary += '<div style="margin-top: 16px; font-size: 20px; font-weight: 900; color: #FF6B35;">Total: ₹' + total + '</div>';
            document.getElementById('cartSummary').innerHTML = summary;
            document.getElementById('bookingModal').classList.add('show');
            toggleCart();
        }
        
        function closeBookingModal() {
            document.getElementById('bookingModal').classList.remove('show');
        }
        
        function submitBooking(event) {
            event.preventDefault();
            const servicesText = cart.map((s, i) => (i+1) + '. ' + s.display_name + ' - ₹' + (s.Price + 99)).join(', ');
            const total = cart.reduce((sum, s) => sum + s.Price + 99, 0);
            const data = {
                timestamp: new Date().toLocaleString('en-IN', {timeZone: 'Asia/Kolkata'}),
                name: document.getElementById('customerName').value,
                whatsapp: document.getElementById('customerPhone').value,
                service: servicesText,
                price: cart.reduce((sum, s) => sum + s.Price, 0).toString(),
                visit_charge: (cart.length * 99).toString(),
                total: total.toString(),
                address: document.getElementById('customerArea').value + ', ' + document.getElementById('customerAddress').value,
                date_time: document.getElementById('serviceDateTime').value,
                status: 'Pending',
                notes: 'Website booking'
            };
            fetch('https://script.google.com/macros/s/AKfycbwMSFSDKAZ0AABl1WEfBB0iVycPhR_bb-8pGdSr0Wj5PB6FEW3n7MihNNHkmNg4B27pJQ/exec', {
                method: 'POST',
                mode: 'no-cors',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            });
            alert('✅ Booking Confirmed!\nTotal: ₹' + total + '\n\nWe will call within 15 minutes.');
            closeBookingModal();
            cart = [];
            updateCartBadge();
            updateCartPanel();
            event.target.reset();
        }
        
        function showServiceGroups(category) {
            currentCategory = category;
            document.getElementById('categorySelection').classList.add('hidden');
            document.getElementById('serviceGroups').classList.remove('hidden');
            document.getElementById('groupsTitle').textContent = category + ' Services';
            const list = document.getElementById('groupsList');
            list.innerHTML = '';
            if (category === 'Driver') {
                showServicesInGroup(category, null);
            } else {
                const groups = serviceData[category];
                for (const groupName in groups) {
                    const services = groups[groupName];
                    const card = document.createElement('div');
                    card.className = 'group-card';
                    card.onclick = function() { showServicesInGroup(category, groupName); };
                    card.innerHTML = '<div class="group-title">' + groupName + '</div><div style="color: #666; font-size: 14px;">' + services.length + ' services</div>';
                    list.appendChild(card);
                }
            }
        }
        
        function showServicesInGroup(category, groupName) {
            currentGroup = groupName;
            document.getElementById('serviceGroups').classList.add('hidden');
            document.getElementById('servicesSection').classList.remove('hidden');
            let services;
            if (category === 'Driver') {
                services = serviceData.Driver;
                document.getElementById('servicesTitle').textContent = 'Driver Services';
            } else {
                services = serviceData[category][groupName];
                document.getElementById('servicesTitle').textContent = groupName;
            }
            const list = document.getElementById('servicesList');
            list.innerHTML = '';
            services.forEach(function(service) {
                const card = document.createElement('div');
                card.className = 'service-card';
                card.innerHTML = '<div class="service-name">' + service.display_name + '</div><div class="service-price">₹' + service.Price + '</div><div style="font-size: 13px; opacity: 0.7; margin-bottom: 12px;">+ ₹99 visit</div><button class="add-to-cart-btn" onclick=\'addToCart(' + JSON.stringify(service) + ')\'>Add to Cart</button>';
                list.appendChild(card);
            });
        }
        
        function goBackToCategories() {
            document.getElementById('serviceGroups').classList.add('hidden');
            document.getElementById('categorySelection').classList.remove('hidden');
        }
        
        function goBackToGroups() {
            document.getElementById('servicesSection').classList.add('hidden');
            if (currentCategory === 'Driver') {
                goBackToCategories();
            } else {
                document.getElementById('serviceGroups').classList.remove('hidden');
            }
        }
        
        function openPartnerModal() {
            document.getElementById('partnerModal').classList.add('show');
        }
        
        function closePartnerModal() {
            document.getElementById('partnerModal').classList.remove('show');
        }
        
        function switchLang(lang) {
            document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('partnerFormEn').classList.toggle('hidden', lang === 'hi');
            document.getElementById('partnerFormHi').classList.toggle('hidden', lang === 'en');
        }
        
        function submitPartnerRegistration(event) {
            event.preventDefault();
            const form = event.target;
            const data = {
                timestamp: new Date().toLocaleString('en-IN', {timeZone: 'Asia/Kolkata'}),
                name: form.partnerName.value,
                phone: form.partnerPhone.value,
                category: form.partnerCategory.value,
                experience: form.partnerExperience.value + ' years',
                area: form.partnerArea.value,
                license: form.partnerLicense.value,
                bio: form.partnerBio.value,
                status: 'New'
            };
            fetch('https://script.google.com/macros/s/AKfycbwMSFSDKAZ0AABl1WEfBB0iVycPhR_bb-8pGdSr0Wj5PB6FEW3n7MihNNHkmNg4B27pJQ/exec', {
                method: 'POST',
                mode: 'no-cors',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ type: 'partner', ...data })
            });
            alert('✅ Registration Submitted!\n\nWe will call you within 24 hours.\n\nPhone: ' + data.phone);
            closePartnerModal();
            form.reset();
        }
        
        document.querySelectorAll('nav a').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) window.scrollTo({ top: target.offsetTop - 80, behavior: 'smooth' });
            });
        });
    </script>
</body>
</html>
